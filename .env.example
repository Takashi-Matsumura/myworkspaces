DATABASE_URL="postgresql://myworkspaces:myworkspaces@localhost:5432/myworkspaces?schema=public"

# セッション Cookie の署名鍵。本番では十分長いランダム文字列を設定する (>= 32 bytes 推奨)。
SESSION_SECRET="change-me-in-production-please-use-a-long-random-string"

# opencode サイドカー (ヘッドレス serve) の Basic 認証パスワード。
# 設定すると `OPENCODE_SERVER_USERNAME=opencode` とセットで Basic 認証が有効になる。
# 空のままだと unsecured 警告が出るが、per-user bridge network に閉じているので
# 開発用途では空でも問題ない。本番で Next.js 以外からも叩く場合は必ず設定する。
OPENCODE_SERVER_PASSWORD=""

# opencode サイドカーのメモリ上限 (bytes)。省略時 512MiB。
# 実測で opencode serve プロセス単体の RSS は約 280MB。
# OPENCODE_MEMORY_BYTES=536870912

# --- Biz パネル DeepSearch (Phase B 以降) ---

# 検索プロバイダ。tavily | brave | serper のどれかを選択。Phase B では tavily のみ実装、
# 他は Phase C 以降で実装予定。
BIZ_SEARCH_PROVIDER=tavily

# Tavily API key (https://app.tavily.com/)。BIZ_SEARCH_PROVIDER=tavily の時に必要。
TAVILY_API_KEY=""

# (Phase C 以降) 他プロバイダの API キー。今は実装スタブのみ。
# BRAVE_API_KEY=""
# SERPER_API_KEY=""

# opencode サイドカーから Next.js の内部 API (/api/biz/internal/*) を叩くための共有トークン。
# サイドカーには Env で渡し、Next.js は X-Biz-Tool-Token ヘッダで検証する。
# 32 byte 以上のランダム hex を推奨。空の場合 web_search tool は無効化される。
# 例: BIZ_TOOL_TOKEN="$(openssl rand -hex 32)"
BIZ_TOOL_TOKEN=""

# Next.js のホスト URL。opencode tool が host.docker.internal で叩くため、
# 通常 :3000 で問題ない。custom port を使う場合のみ変更。
# BIZ_NEXTJS_INTERNAL_URL="http://host.docker.internal:3000"
