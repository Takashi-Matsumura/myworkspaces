// myworkspaces Phase 2: ユーザ管理スキーマ
//
// User: ログイン可能なユーザ。username は一意。passwordHash は bcrypt
// Session: Cookie で持つ不透明トークン。期限切れはクリーンアップ対象
// Workspace: ユーザごとのワークスペース (コンテナ内 /root/workspaces/{id}/ と 1:1)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String      @id @default(cuid())
  username        String      @unique
  passwordHash    String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  networkIsolated Boolean     @default(false)
  workspaces      Workspace[]
  sessions        Session[]
  whiteboard      Whiteboard?
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Workspace {
  id            String   @id
  userId        String
  label         String
  createdAt     DateTime @default(now())
  lastOpenedAt  DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ユーザごとの Excalidraw 白板。User と 1:1。
// elements は Excalidraw の非削除要素配列をそのまま JSON で保存。
// appState は scrollX / scrollY / zoom など復元に必要な最小部分のみ。
model Whiteboard {
  userId    String   @id
  elements  Json
  appState  Json
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
