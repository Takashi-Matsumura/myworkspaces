// myworkspaces Phase 2: ユーザ管理スキーマ
//
// User: ログイン可能なユーザ。username は一意。passwordHash は bcrypt
// Session: Cookie で持つ不透明トークン。期限切れはクリーンアップ対象
// Workspace: ユーザごとのワークスペース (コンテナ内 /root/workspaces/{id}/ と 1:1)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String        @id @default(cuid())
  username        String        @unique
  passwordHash    String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  networkIsolated Boolean       @default(false)
  workspaces      Workspace[]
  sessions        Session[]
  whiteboard      Whiteboard?
  ragDocuments    RagDocument[]
  shareLinks      ShareLink[]
  ropes           Rope[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Workspace {
  id           String   @id
  userId       String
  label        String
  createdAt    DateTime @default(now())
  lastOpenedAt DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ユーザごとの Excalidraw 白板。User と 1:1。
// elements は Excalidraw の非削除要素配列をそのまま JSON で保存。
// appState は scrollX / scrollY / zoom など復元に必要な最小部分のみ。
model Whiteboard {
  userId    String   @id
  elements  Json
  appState  Json
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// RAG に取り込まれたドキュメントのメタデータ。実データ (チャンク・埋め込み) は
// ユーザ固有の RAG サイドカー (myworkspaces-rag-{sub}) 内の Qdrant に格納される。
// このテーブルは Web UI の一覧表示と削除操作のためのハンドルに過ぎない。
// id は Qdrant payload 側の doc_id と同値 (1 ドキュメント = 複数チャンク)。
//
// Phase E-B-2 で追加:
//   workspaceId / relativePath: Biz パネルの sync-rag が
//     reports/<file>.md / research/<file>.md を取り込む時に、同じファイルの再
//     ingest を upsert で扱うためのユニーク識別子。手動アップロード経路 (旧 /api/rag/upload)
//     はこれらを NULL のままにする (既存の挙動と互換)。
//   updatedAt: 最終取り込み時刻 (Biz タブの「最終 ingest 時刻」表示用)。
model RagDocument {
  id           String   @id @default(cuid())
  userId       String
  filename     String
  bytes        Int
  chunkCount   Int
  workspaceId  String?
  relativePath String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId, relativePath], name: "uniq_user_workspace_path")
  @@index([userId])
  @@index([userId, updatedAt])
}

// Phase E-C-3: 署名付き共有 URL。
// reports/<topic>-summary.md などを Cookie 認証なしで公開閲覧できるトークンを発行する。
// /share/<token> で /biz/preview と同じ render を no-auth で表示。
//
// 同一 (userId, workspaceId, relativePath) は upsert (= URL を再発行しても token は維持)。
// expiresAt が NULL なら無期限。クライアント側で期限切れは 410 Gone で表示する。
model ShareLink {
  id           String    @id @default(cuid())
  token        String    @unique
  userId       String
  workspaceId  String
  relativePath String
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId, relativePath], name: "uniq_share_user_workspace_path")
  @@index([userId])
  @@index([token])
}

// A2A (Agent-to-Agent) ロープ。Biz パネルと Code パネルの opencode session を
// 結び、片方の session.idle を観測すると assistant 応答を抽出して相手 session に
// inject する watch 型自動 relay。v1 は session-to-session バインド (ユーザが
// session を切替えたらロープを作り直す)。
//
// hopLimit: ホップ数上限 (default 5)。これを超えるメッセージは relay しない。
// active: false にすると listener から外される (キルスイッチ)。
model Rope {
  id            String       @id @default(cuid())
  userId        String
  fromPanel     String // "biz" | "code"
  toPanel       String // "biz" | "code"
  fromSessionId String // opencode session.id
  toSessionId   String
  hopLimit      Int          @default(5)
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      A2AMessage[]

  @@index([userId, active])
  @@index([fromSessionId])
}

// ロープ経由で relay されたメッセージの監査ログ。
// delivered: true 相手 session に POST 成功、false スキップされた (skipReason 参照)。
// contentHash: SHA-256 hex。直近 N 件と一致したら dedup でスキップ。
// contentPreview: 先頭 200 文字 (audit / debug 用、本文全体は保存しない)。
model A2AMessage {
  id             String   @id @default(cuid())
  ropeId         String
  fromPanel      String
  hopCount       Int
  contentHash    String
  contentPreview String
  delivered      Boolean  @default(false)
  skipReason     String? // "hopLimit" | "dedup" | null
  createdAt      DateTime @default(now())
  rope           Rope     @relation(fields: [ropeId], references: [id], onDelete: Cascade)

  @@index([ropeId, createdAt])
}
